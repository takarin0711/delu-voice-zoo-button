{
  "manifest_version": 3,
  "name": "Delu Voice Zoo Button",
  "version": "0.3.0",
  "description": "Adds a voice button to Delutaya's YouTube channel page",
  "web_accessible_resources": [
    {
      "resources": ["voice/*.mp3"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/@delutaya*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
